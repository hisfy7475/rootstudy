{
  "name": "studycafe-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "verify:ios-simulator": "expo prebuild --platform ios && xcodebuild -workspace ios/app.xcworkspace -scheme app -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' CODE_SIGNING_ALLOWED=NO build",
    "verify:android-debug": "expo prebuild --platform android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "expo": "~55.0.8",
    "expo-constants": "^55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-device": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-image-picker": "~55.0.14",
    "expo-linking": "^55.0.8",
    "expo-notifications": "~55.0.14",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
