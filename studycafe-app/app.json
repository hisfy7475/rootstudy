{
  "expo": {
    "name": "루트스터디",
    "slug": "studycafe-app",
    "version": "1.0.0",
    "scheme": "rootstudy",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4F46E5"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "채팅에 이미지를 보내기 위해 사진 라이브러리 접근이 필요합니다.",
          "cameraPermission": "채팅에 사진을 촬영해 보내기 위해 카메라 접근이 필요합니다."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rootstudy.app",
      "associatedDomains": [
        "applinks:www.rootstudy.co.kr",
        "applinks:rootstudy.co.kr"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "itms-appss",
          "itms-apps",
          "ispmobile",
          "kftc-bankpay",
          "kakaotalk",
          "supertoss",
          "lpayapp",
          "samsungpay",
          "shinhan-sr-ansimclick",
          "kb-acp",
          "hdcardappcardansimclick",
          "lotteappcard",
          "hanawalletmembers",
          "nhappcardansimclick",
          "citimobileapp",
          "payco",
          "cloudpay"
        ]
      }
    },
    "android": {
      "package": "com.rootstudy.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.rootstudy.co.kr",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "rootstudy.co.kr",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "95fb04dd-e09b-427e-a9f0-29e643ae4f7c"
      }
    },
    "owner": "buildersgate"
  }
}
