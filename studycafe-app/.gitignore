# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# Firebase / FCM
google-services.json
GoogleService-Info.plist
*-firebase-adminsdk-*.json
fcm-service-account*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Local Expo modules — gradle/cmake build artifacts only (source code is tracked)
modules/**/build/
modules/**/.gradle/
modules/**/.cxx/
modules/**/*.iml
